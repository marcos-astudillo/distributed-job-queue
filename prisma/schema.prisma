enum JobState {
  queued
  in_progress
  succeeded
  failed
}

model Job {
  job_id       String   @id @default(cuid())
  type         String
  payload      Json
  state        JobState @default(queued)
  run_at       DateTime
  attempts     Int      @default(0)
  max_attempts Int      @default(3)
  last_error   String?

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([state, run_at])
}